# Trakt app credentials from https://trakt.tv/oauth/applications/new
MCP_TRAKT_CLIENT_ID=
MCP_TRAKT_CLIENT_SECRET=

# Optional if you already have OAuth tokens. Most users should run setup instead.
MCP_TRAKT_ACCESS_TOKEN=
MCP_TRAKT_REFRESH_TOKEN=
MCP_TRAKT_TOKEN_EXPIRES_AT=

# Optional verbose Trakt API diagnostics. Redacts API key and bearer token values.
MCP_TRAKT_DEBUG=

# File-backed auth for Docker/persistent deployments.
MCP_TRAKT_AUTH_STORE=file
MCP_TRAKT_TOKEN_FILE=/data/trakt-tokens.json

# Remote MCP HTTP settings.
MCP_TRANSPORT=http
MCP_HTTP_HOST=0.0.0.0
MCP_HTTP_PORT=3000
MCP_HTTP_PATH=/mcp

# Strongly recommended for remote exposure unless protected by OAuth/reverse proxy.
MCP_HTTP_AUTH_TOKEN=change-this-long-random-token
